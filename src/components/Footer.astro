---
// src/components/Footer.astro
const pathname = Astro.url.pathname;

const isHome = pathname === '/My-Portfolio/' || pathname === '/My-Portfolio' || pathname === '/';
const isAbout = pathname.includes('/about');
const isWorks = pathname.includes('/works');
const isContact = pathname.includes('/contact');
---

<footer class="footer-area">
    <div class="container">
        <div class="footer-content text-center">
            <a href="/My-Portfolio/" class="logo">
                <img src="/My-Portfolio/assets/logo.png" alt="Logo">
            </a>
            
            <ul class="footer-menu">
                <li class={isHome ? "active" : ""}><a href="/My-Portfolio/">Home</a></li>
                <li class={isAbout ? "active" : ""}><a href="/My-Portfolio/about/">About</a></li>
                <li class={isWorks ? "active" : ""}><a href="/My-Portfolio/works/">Works</a></li>
                <li class={isContact ? "active" : ""}><a href="/My-Portfolio/contact/">Contact</a></li>
            </ul>

            <p class="copyright">
                © All rights reserved by <span><a href="#">Raiyan Uddin</a></span>
            </p>
        </div>
    </div>
</footer>
