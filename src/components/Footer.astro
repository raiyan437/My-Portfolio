---
// src/components/Footer.astro
const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const isHome = pathname === base || pathname === `${base}index.html`;
const isAbout = pathname.includes('/about');
const isWorks = pathname.includes('/works');
const isContact = pathname.includes('/contact');
---

<footer class="footer-area">
    <div class="container">
        <div class="footer-content text-center">
            <a href={base} class="logo">
                <img src={base + "assets/logo.png"} alt="Logo">
            </a>
            
            <ul class="footer-menu">
                <li class={isHome ? "active" : ""}><a href={base}>Home</a></li>
                <li class={isAbout ? "active" : ""}><a href={base + "about"}>About</a></li>
                <li class={isWorks ? "active" : ""}><a href={base + "works"}>Works</a></li>
                <li class={isContact ? "active" : ""}><a href={base + "contact"}>Contact</a></li>
            </ul>

            <p class="copyright">
                © All rights reserved by <span><a href="#">Raiyan Uddin</a></span>
            </p>
        </div>
    </div>
</footer>
