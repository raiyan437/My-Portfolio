---
// src/components/Footer.astro
const pathname = Astro.url.pathname;

const isHome = pathname === '/' || pathname === '/index.html' || pathname === '/index';
const isAbout = pathname.startsWith('/about');
const isWorks = pathname.startsWith('/works');
const isContact = pathname.startsWith('/contact');
---

<footer class="footer-area">
    <div class="container">
        <div class="footer-content text-center">
            <a href="/" class="logo">
                <img src="/assets/logo.png" alt="Logo">
            </a>
            
            <ul class="footer-menu">
                <li class={isHome ? "active" : ""}><a href="/">Home</a></li>
                <li class={isAbout ? "active" : ""}><a href="/about">About</a></li>
                <li class={isWorks ? "active" : ""}><a href="/works">Works</a></li>
                <li class={isContact ? "active" : ""}><a href="/contact">Contact</a></li>
            </ul>

            <p class="copyright">
                © All rights reserved by <span><a href="#">Raiyan Uddin</a></span>
            </p>
        </div>
    </div>
</footer>
