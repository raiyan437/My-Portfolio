---
// src/components/Header.astro
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const pathname = Astro.url.pathname;

const relativePath = pathname.startsWith(base) 
  ? '/' + pathname.slice(base.length) 
  : pathname;

const isHome = relativePath === '/' || relativePath === '/index.html' || relativePath === '/index' || relativePath === '';
const isAbout = relativePath.includes('about');
const isSkills = relativePath.includes('skills');
const isWorks = relativePath.includes('works');
const isCertifications = relativePath.includes('certifications');
const isContact = relativePath.includes('contact');
---

<header class="header-area">
    <div class="container">
        <div class="gx-row d-flex align-items-center justify-content-between">
            <a href={base} class="logo">
                <img src={`${base}assets/logo.png`} alt="Logo">
            </a>

            <!-- Navigation Menu -->
            <nav class="navbar" id="navbar">
                <ul class="menu" id="menu-main-menu">
                    <li class={isHome ? "active" : ""}><a href={base}>Home</a></li>
                    <li class={isAbout ? "active" : ""}><a href={`${base}about/`}>About</a></li>
                    <li class={isSkills ? "active" : ""}><a href={`${base}skills/`}>Skills</a></li>
                    <li class={isWorks ? "active" : ""}><a href={`${base}works/`}>Works</a></li>
                    <li class={isCertifications ? "active" : ""}><a href={`${base}certifications/`}>Certifications</a></li>
                    <li class={isContact ? "active" : ""}><a href={`${base}contact/`}>Contact</a></li>
                </ul>
            </nav>

            <a href={`${base}contact/`} class="theme-btn">Let's talk</a>

            <!-- Mobile Toggle Menu -->
            <div class="show-menu" id="show-menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </div>
</header>
