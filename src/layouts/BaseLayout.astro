---
// src/layouts/BaseLayout.astro
interface Props {
  title?: string;
  bodyClass?: string;
}

const { title = "Gridx - Personal Portfolio Website", bodyClass = "main-homepage" } = Astro.props;
import Preloader from '../components/Preloader.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css?family=Inter%3A100%2C200%2C300%2C400%2C500%2C600%2C700%2C800%2C%26subset%3Dlatin%2Clatin-ext&ver=1.0.0" rel="stylesheet">
    <!-- Local CSS Libraries -->
    <link rel="stylesheet" href="/assets/bootstrap.min.css">
    <link rel="stylesheet" href="/assets/aos.css">
    <!-- Iconoir CSS CDN -->
    <link rel="stylesheet" href="https://wpriverthemes.com/gridx/wp-content/themes/gridx/assets/css/iconoir.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/style.css">
</head>
<body class={bodyClass}>

    <!-- Preloader -->
    <Preloader />

    <!-- Header -->
    <Header />

    <!-- Page Specific Slot -->
    <slot />

    <!-- Footer -->
    <Footer />

    <!-- Local JS Libraries -->
    <script is:inline src="/assets/bootstrap.bundle.min.js"></script>
    <script is:inline src="/assets/aos.js"></script>
    <!-- Custom JS -->
    <script is:inline src="/main.js"></script>
</body>
</html>
