---
// src/pages/works/bsec-ipo-system.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="BSEC IPO System - Project Details - Raiyan Uddin" bodyClass="main-workdetails-page">
    <section class="project-details-wrap">
        <div class="container">

            <!-- Breadcrumb Section -->
            <section class="breadcrumb-area">
                <div class="container">
                    <div class="breadcrumb-content" data-aos="fade-up">
                        <p>BRANDING & SYSTEM - BSEC IPO SYSTEM</p>
                        <h1 class="section-heading">
                            <img src="/assets/star-2.png" alt="star">
                            Enterprise financial application & <br>IPO application workflow
                            <img src="/assets/star-2.png" alt="star">
                        </h1>
                    </div>
                </div>
            </section>

            <!-- Hero Banner Image -->
            <div class="project-details-img" data-aos="zoom-in">
                <img src="/assets/project4.jpeg" alt="BSEC IPO System Banner">
            </div>

            <!-- Info Box Card -->
            <div data-aos="zoom-in">
                <div class="d-flex project-infos-wrap shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <img src="/assets/icon2.png" alt="Star" class="star-icon">
                    
                    <div class="project-details-info flex-1">
                        <h4>BSEC IPO System</h4>
                        <p>End-to-end Quality Assurance testing for Bangladesh Securities and Exchange Commission (BSEC) Initial Public Offering (IPO) system. Verified multi-role approval flows, investor registration forms, and secure document upload modules.</p>
                    </div>

                    <div class="project-details-info flex-1">
                        <h4>About</h4>
                        <p>Government enterprise software testing enforcing security compliance, data validation integrity, and high-concurrency stress resilience.</p>
                    </div>
                </div>
            </div>

            <!-- Project Overview & Details Meta Box -->
            <div data-aos="zoom-in">
                <div class="project-about-2 d-flex shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <div class="left-details">
                        <img src="/assets/icon2.png" alt="Star" class="star-icon">
                        <ul>
                            <li>
                                <p>Year</p>
                                <h5>2024</h5>
                            </li>
                            <li>
                                <p>Client</p>
                                <h5>BSEC</h5>
                            </li>
                            <li>
                                <p>Services</p>
                                <h5>Enterprise System QA</h5>
                            </li>
                            <li>
                                <p>Project</p>
                                <h5>BSEC IPO System</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="right-details">
                        <h4>Description</h4>
                        <p>Comprehensive system testing, workflow validation, financial form verification, and regression test execution for the BSEC IPO portal.</p>
                    </div>
                </div>
            </div>

            <!-- Next Project Button -->
            <div class="container d-flex align-items-center justify-content-center mt-24 mb-24" data-aos="zoom-in">
                <a href="/works/dnothi" class="big-btn shadow-box">Next Project</a>
            </div>

        </div>
    </section>
</BaseLayout>
