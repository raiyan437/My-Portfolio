---
// src/pages/works/mrmax.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="MrMax - Project Details - Raiyan Uddin" bodyClass="main-workdetails-page">
    <section class="project-details-wrap">
        <div class="container">

            <!-- Breadcrumb Section -->
            <section class="breadcrumb-area">
                <div class="container">
                    <div class="breadcrumb-content" data-aos="fade-up">
                        <p>WEB DESIGNING - MRMAX</p>
                        <h1 class="section-heading">
                            <img src="/assets/star-2.png" alt="star">
                            High performance web app <br>for modern business
                            <img src="/assets/star-2.png" alt="star">
                        </h1>
                    </div>
                </div>
            </section>

            <!-- Hero Banner Image -->
            <div class="project-details-img" data-aos="zoom-in">
                <img src="/assets/project1.jpeg" alt="MrMax Project Banner">
            </div>

            <!-- Info Box Card -->
            <div data-aos="zoom-in">
                <div class="d-flex project-infos-wrap shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <img src="/assets/icon2.png" alt="Star" class="star-icon">
                    
                    <div class="project-details-info flex-1">
                        <h4>MrMax</h4>
                        <p>Comprehensive web application testing and development verification for MrMax ecommerce platform ensuring high performance, responsive layout, and seamless user interaction across devices.</p>
                        <p>Implemented end-to-end user journey validation, bug tracking, and performance optimization checks to maintain system stability and reliability.</p>
                    </div>

                    <div class="project-details-info flex-1">
                        <h4>About</h4>
                        <p>MrMax project focuses on delivering robust user experiences with stringent Quality Assurance standards and thorough test coverage across core application workflows.</p>
                    </div>
                </div>
            </div>

            <!-- Project Showcase Banner 2 -->
            <div class="project-details-2-img mb-24" data-aos="zoom-in">
                <img src="/assets/project-dt-1.jpeg" alt="Showcase Banner">
            </div>

            <!-- Project Gallery Row 1 -->
            <div class="row mb-24">
                <div class="col-md-6 mb-24" data-aos="zoom-in">
                    <div class="project-details-3-img">
                        <img src="/assets/project1.jpeg" alt="Gallery 1">
                    </div>
                </div>
                <div class="col-md-6 mb-24" data-aos="zoom-in">
                    <div class="project-details-3-img">
                        <img src="/assets/project2.jpeg" alt="Gallery 2">
                    </div>
                </div>
            </div>

            <!-- Project Overview & Details Meta Box -->
            <div data-aos="zoom-in">
                <div class="project-about-2 d-flex shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <div class="left-details">
                        <img src="/assets/icon2.png" alt="Star" class="star-icon">
                        <ul>
                            <li>
                                <p>Year</p>
                                <h5>2023</h5>
                            </li>
                            <li>
                                <p>Client</p>
                                <h5>MrMax</h5>
                            </li>
                            <li>
                                <p>Services</p>
                                <h5>Web Designing & QA</h5>
                            </li>
                            <li>
                                <p>Project</p>
                                <h5>MrMax</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="right-details">
                        <h4>Description</h4>
                        <p>Thorough web interface verification, test suite execution, cross-browser compatibility testing, and performance benchmarking for the MrMax platform.</p>
                    </div>
                </div>
            </div>

            <!-- Next Project Button -->
            <div class="container d-flex align-items-center justify-content-center mt-24 mb-24" data-aos="zoom-in">
                <a href="/works/qa-brains-java-playwright" class="big-btn shadow-box">Next Project</a>
            </div>

        </div>
    </section>
</BaseLayout>
