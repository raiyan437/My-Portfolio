---
// src/pages/works/dnothi.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="dNothi - Project Details - Raiyan Uddin" bodyClass="main-workdetails-page">
    <section class="project-details-wrap">
        <div class="container">

            <!-- Breadcrumb Section -->
            <section class="breadcrumb-area">
                <div class="container">
                    <div class="breadcrumb-content" data-aos="fade-up">
                        <p>WEB DESIGNING - DNOTHI</p>
                        <h1 class="section-heading">
                            <img src="/My-Portfolio/assets/star-2.png" alt="star">
                            National digital document management <br>& e-filing system
                            <img src="/My-Portfolio/assets/star-2.png" alt="star">
                        </h1>
                    </div>
                </div>
            </section>

            <!-- Hero Banner Image -->
            <div class="project-details-img" data-aos="zoom-in">
                <img src="/My-Portfolio/assets/project7.png" alt="dNothi Banner">
            </div>

            <!-- Info Box Card -->
            <div data-aos="zoom-in">
                <div class="d-flex project-infos-wrap shadow-box mb-24">
                    <img src="/My-Portfolio/assets/bg1.png" alt="BG" class="bg-img">
                    <img src="/My-Portfolio/assets/icon2.png" alt="Star" class="star-icon">
                    
                    <div class="project-details-info flex-1">
                        <h4>dNothi</h4>
                        <p>Functional, UI design, and performance testing for dNothi (Government E-Nothi System), Bangladesh's national administrative digital file tracking platform. Enabled official note approvals, digital letter dispatch, and document archiving across government ministries.</p>
                    </div>

                    <div class="project-details-info flex-1">
                        <h4>About</h4>
                        <p>Nationwide e-filing web platform validation covering user permission hierarchies, digital signature verification, audit trail logging, and system response times under heavy civil service load.</p>
                    </div>
                </div>
            </div>

            <!-- Project Showcase Banner 2 -->
            <div class="project-details-2-img mb-24" data-aos="zoom-in">
                <img src="/My-Portfolio/assets/dnothi_detail.jpg" alt="National E-Filing Showcase Banner">
            </div>

            <!-- Project Overview & Details Meta Box -->
            <div data-aos="zoom-in">
                <div class="project-about-2 d-flex shadow-box mb-24">
                    <img src="/My-Portfolio/assets/bg1.png" alt="BG" class="bg-img">
                    <div class="left-details">
                        <img src="/My-Portfolio/assets/icon2.png" alt="Star" class="star-icon">
                        <ul>
                            <li>
                                <p>Year</p>
                                <h5>2024</h5>
                            </li>
                            <li>
                                <p>Client</p>
                                <h5>Government of Bangladesh</h5>
                            </li>
                            <li>
                                <p>Services</p>
                                <h5>Web Designing & QA</h5>
                            </li>
                            <li>
                                <p>Project</p>
                                <h5>dNothi</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="right-details">
                        <h4>Description</h4>
                        <p>Detailed web UI design validation, user role permission verification, digital signature integration testing, document security auditing, and bug tracking for the national e-filing platform.</p>
                    </div>
                </div>
            </div>

            <!-- Next Project Button -->
            <div class="container d-flex align-items-center justify-content-center mt-24 mb-24" data-aos="zoom-in">
                <a href="/My-Portfolio/works/practice-management-system/" class="big-btn shadow-box">Next Project</a>
            </div>

        </div>
    </section>
</BaseLayout>



