---
// src/pages/works/qa-brains-ts-playwright.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="QA Brains Automation Project (TypeScript & Playwright) - Raiyan Uddin" bodyClass="main-workdetails-page">
    <section class="project-details-wrap">
        <div class="container">

            <!-- Breadcrumb Section -->
            <section class="breadcrumb-area">
                <div class="container">
                    <div class="breadcrumb-content" data-aos="fade-up">
                        <p>TYPESCRIPT & PLAYWRIGHT - QA BRAINS AUTOMATION</p>
                        <h1 class="section-heading">
                            <img src="/My-Portfolio/assets/star-2.png" alt="star">
                            Modern TypeScript Playwright suite <br>for end-to-end testing
                            <img src="/My-Portfolio/assets/star-2.png" alt="star">
                        </h1>
                    </div>
                </div>
            </section>

            <!-- Hero Banner Image -->
            <div class="project-details-img" data-aos="zoom-in">
                <img src="/My-Portfolio/assets/project3.png" alt="QA Brains Automation Project Banner">
            </div>

            <!-- Info Box Card -->
            <div data-aos="zoom-in">
                <div class="d-flex project-infos-wrap shadow-box mb-24">
                    <img src="/My-Portfolio/assets/bg1.png" alt="BG" class="bg-img">
                    <img src="/My-Portfolio/assets/icon2.png" alt="Star" class="star-icon">
                    
                    <div class="project-details-info flex-1">
                        <h4>QA Brains Automation</h4>
                        <p>End-to-end browser testing solution engineered with TypeScript and Playwright Test runner. Integrates modular Page Object Model pattern, visual regression capabilities, API mocks, automatic retries, and automated GitHub Actions CI pipelines.</p>
                        <p>Designed for fast execution, type safety, modular test maintenance, network intercept mocking, and interactive HTML trace reporting.</p>
                    </div>

                    <div class="project-details-info flex-1">
                        <h4>About</h4>
                        <p>High-efficiency automation framework supporting asynchronous test execution, web assertion verification, network API fixtures, and automated browser trace inspection.</p>
                    </div>
                </div>
            </div>

            <!-- Project Showcase Banner 2 -->
            <div class="project-details-2-img mb-24" data-aos="zoom-in">
                <img src="/My-Portfolio/assets/qa_ts_detail.jpg" alt="TypeScript Playwright Showcase Banner">
            </div>

            <!-- Project Overview & Details Meta Box -->
            <div data-aos="zoom-in">
                <div class="project-about-2 d-flex shadow-box mb-24">
                    <img src="/My-Portfolio/assets/bg1.png" alt="BG" class="bg-img">
                    <div class="left-details">
                        <img src="/My-Portfolio/assets/icon2.png" alt="Star" class="star-icon">
                        <ul>
                            <li>
                                <p>Year</p>
                                <h5>2024</h5>
                            </li>
                            <li>
                                <p>Client</p>
                                <h5>QA Brains</h5>
                            </li>
                            <li>
                                <p>Services</p>
                                <h5>TypeScript & Playwright</h5>
                            </li>
                            <li>
                                <p>Project</p>
                                <h5>QA Brains Automation</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="right-details">
                        <h4>Description</h4>
                        <p>Full-stack web application automation, custom assertion libraries, fixture setup, visual diff testing, and GitHub Actions CI integration using Playwright and TypeScript.</p>
                    </div>
                </div>
            </div>

            <!-- Next Project Button -->
            <div class="container d-flex align-items-center justify-content-center mt-24 mb-24" data-aos="zoom-in">
                <a href="/My-Portfolio/works/restful-booker/" class="big-btn shadow-box">Next Project</a>
            </div>

        </div>
    </section>
</BaseLayout>



