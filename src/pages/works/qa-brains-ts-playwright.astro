---
// src/pages/works/qa-brains-ts-playwright.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="QA Brains Automation Project (TypeScript & Playwright) - Raiyan Uddin" bodyClass="main-workdetails-page">
    <section class="project-details-wrap">
        <div class="container">

            <!-- Breadcrumb Section -->
            <section class="breadcrumb-area">
                <div class="container">
                    <div class="breadcrumb-content" data-aos="fade-up">
                        <p>TYPESCRIPT & PLAYWRIGHT - QA BRAINS AUTOMATION PROJECT</p>
                        <h1 class="section-heading">
                            <img src={base + "assets/star-2.png"} alt="star">
                            Modern TypeScript Playwright suite <br>for end-to-end testing
                            <img src={base + "assets/star-2.png"} alt="star">
                        </h1>
                    </div>
                </div>
            </section>

            <!-- Hero Banner Image -->
            <div class="project-details-img" data-aos="zoom-in">
                <img src={base + "assets/project4.jpeg"} alt="QA Brains Automation Project Banner">
            </div>

            <!-- Info Box Card -->
            <div data-aos="zoom-in">
                <div class="d-flex project-infos-wrap shadow-box mb-24">
                    <img src={base + "assets/bg1.png"} alt="BG" class="bg-img">
                    <img src={base + "assets/icon2.png"} alt="Star" class="star-icon">
                    
                    <div class="project-details-info flex-1">
                        <h4>QA Brains Automation Project</h4>
                        <p>End-to-end browser testing solution engineered with TypeScript and Playwright. Integrates Page Object Model pattern, visual regression capabilities, API mocks, and automated CI pipelines.</p>
                        <p>Designed for fast execution, modular test maintenance, and clear HTML artifact reporting.</p>
                    </div>

                    <div class="project-details-info flex-1">
                        <h4>About</h4>
                        <p>High-efficiency automation framework supporting asynchronous test execution, web assertion verification, and automated browser traces.</p>
                    </div>
                </div>
            </div>

            <!-- Project Showcase Banner 2 -->
            <div class="project-details-2-img mb-24" data-aos="zoom-in">
                <img src={base + "assets/project-dt-1.jpeg"} alt="Showcase Banner">
            </div>

            <!-- Project Overview & Details Meta Box -->
            <div data-aos="zoom-in">
                <div class="project-about-2 d-flex shadow-box mb-24">
                    <img src={base + "assets/bg1.png"} alt="BG" class="bg-img">
                    <div class="left-details">
                        <img src={base + "assets/icon2.png"} alt="Star" class="star-icon">
                        <ul>
                            <li>
                                <p>Year</p>
                                <h5>2024</h5>
                            </li>
                            <li>
                                <p>Client</p>
                                <h5>QA Brains</h5>
                            </li>
                            <li>
                                <p>Services</p>
                                <h5>TypeScript & Playwright</h5>
                            </li>
                            <li>
                                <p>Project</p>
                                <h5>QA Brains Automation</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="right-details">
                        <h4>Description</h4>
                        <p>Full-stack web application testing, assertion creation, fixture setup, and GitHub Actions integration using Playwright and TypeScript.</p>
                    </div>
                </div>
            </div>

            <!-- Next Project Button -->
            <div class="container d-flex align-items-center justify-content-center mt-24 mb-24" data-aos="zoom-in">
                <a href={base + "works/restful-booker"} class="big-btn shadow-box">Next Project</a>
            </div>

        </div>
    </section>
</BaseLayout>
