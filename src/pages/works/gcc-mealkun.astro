---
// src/pages/works/gcc-mealkun.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="GCC Mealkun - Project Details - Raiyan Uddin" bodyClass="main-workdetails-page">
    <section class="project-details-wrap">
        <div class="container">

            <!-- Breadcrumb Section -->
            <section class="breadcrumb-area">
                <div class="container">
                    <div class="breadcrumb-content" data-aos="fade-up">
                        <p>MOBILE DESIGNING - GCC MEALKUN</p>
                        <h1 class="section-heading">
                            <img src="/assets/star-2.png" alt="star">
                            Mobile application testing & <br>UI quality validation
                            <img src="/assets/star-2.png" alt="star">
                        </h1>
                    </div>
                </div>
            </section>

            <!-- Hero Banner Image -->
            <div class="project-details-img" data-aos="zoom-in">
                <img src="/assets/project5.jpeg" alt="GCC Mealkun Banner">
            </div>

            <!-- Info Box Card -->
            <div data-aos="zoom-in">
                <div class="d-flex project-infos-wrap shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <img src="/assets/icon2.png" alt="Star" class="star-icon">
                    
                    <div class="project-details-info flex-1">
                        <h4>GCC Mealkun</h4>
                        <p>Quality Assurance and UI/UX validation for GCC Mealkun mobile application, ensuring smooth navigation, responsive layout across various screen resolutions, and error-free checkout operations.</p>
                    </div>

                    <div class="project-details-info flex-1">
                        <h4>About</h4>
                        <p>Mobile QA testing focusing on performance, push notification handling, network throttling resilience, and usability verification.</p>
                    </div>
                </div>
            </div>

            <!-- Project Overview & Details Meta Box -->
            <div data-aos="zoom-in">
                <div class="project-about-2 d-flex shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <div class="left-details">
                        <img src="/assets/icon2.png" alt="Star" class="star-icon">
                        <ul>
                            <li>
                                <p>Year</p>
                                <h5>2023</h5>
                            </li>
                            <li>
                                <p>Client</p>
                                <h5>GCC Mealkun</h5>
                            </li>
                            <li>
                                <p>Services</p>
                                <h5>Mobile Designing & QA</h5>
                            </li>
                            <li>
                                <p>Project</p>
                                <h5>GCC Mealkun</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="right-details">
                        <h4>Description</h4>
                        <p>Mobile interface testing, cross-device compatibility validation, regression execution, and performance assessment.</p>
                    </div>
                </div>
            </div>

            <!-- Next Project Button -->
            <div class="container d-flex align-items-center justify-content-center mt-24 mb-24" data-aos="zoom-in">
                <a href="/works/bsec-ipo-system" class="big-btn shadow-box">Next Project</a>
            </div>

        </div>
    </section>
</BaseLayout>
