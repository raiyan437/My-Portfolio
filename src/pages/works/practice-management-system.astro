---
// src/pages/works/practice-management-system.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Practice Management System - Project Details - Raiyan Uddin" bodyClass="main-workdetails-page">
    <section class="project-details-wrap">
        <div class="container">

            <!-- Breadcrumb Section -->
            <section class="breadcrumb-area">
                <div class="container">
                    <div class="breadcrumb-content" data-aos="fade-up">
                        <p>ARCHITECTURE & SYSTEM - PRACTICE MANAGEMENT SYSTEM</p>
                        <h1 class="section-heading">
                            <img src="/assets/star-2.png" alt="star">
                            Legal & professional practice <br>management portal
                            <img src="/assets/star-2.png" alt="star">
                        </h1>
                    </div>
                </div>
            </section>

            <!-- Hero Banner Image -->
            <div class="project-details-img" data-aos="zoom-in">
                <img src="/assets/project3.jpeg" alt="Practice Management System Banner">
            </div>

            <!-- Info Box Card -->
            <div data-aos="zoom-in">
                <div class="d-flex project-infos-wrap shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <img src="/assets/icon2.png" alt="Star" class="star-icon">
                    
                    <div class="project-details-info flex-1">
                        <h4>Practice Management System</h4>
                        <p>End-to-end software quality engineering for Practice Management System. Tested case tracking, client billing automation, calendar scheduling integrations, and report generation engines.</p>
                    </div>

                    <div class="project-details-info flex-1">
                        <h4>About</h4>
                        <p>Comprehensive legal and corporate practice portal verification ensuring accurate invoicing calculations, secure client record storage, and reliable user authentication.</p>
                    </div>
                </div>
            </div>

            <!-- Project Overview & Details Meta Box -->
            <div data-aos="zoom-in">
                <div class="project-about-2 d-flex shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <div class="left-details">
                        <img src="/assets/icon2.png" alt="Star" class="star-icon">
                        <ul>
                            <li>
                                <p>Year</p>
                                <h5>2024</h5>
                            </li>
                            <li>
                                <p>Client</p>
                                <h5>LegalPractice Corp</h5>
                            </li>
                            <li>
                                <p>Services</p>
                                <h5>Software QA & Testing</h5>
                            </li>
                            <li>
                                <p>Project</p>
                                <h5>Practice Management</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="right-details">
                        <h4>Description</h4>
                        <p>System integration testing, billing calculation verification, case file security testing, and regression suite execution.</p>
                    </div>
                </div>
            </div>

            <!-- Next Project Button -->
            <div class="container d-flex align-items-center justify-content-center mt-24 mb-24" data-aos="zoom-in">
                <a href="/works/mrmax" class="big-btn shadow-box">Next Project</a>
            </div>

        </div>
    </section>
</BaseLayout>
