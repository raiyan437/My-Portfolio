---
// src/pages/works/qa-brains-java-playwright.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="QA Brains Automation Project (Java & Playwright) - Raiyan Uddin" bodyClass="main-workdetails-page">
    <section class="project-details-wrap">
        <div class="container">

            <!-- Breadcrumb Section -->
            <section class="breadcrumb-area">
                <div class="container">
                    <div class="breadcrumb-content" data-aos="fade-up">
                        <p>JAVA & PLAYWRIGHT - QA BRAINS AUTOMATION PROJECT</p>
                        <h1 class="section-heading">
                            <img src="/assets/star-2.png" alt="star">
                            Robust automated testing framework <br>with Java & Playwright
                            <img src="/assets/star-2.png" alt="star">
                        </h1>
                    </div>
                </div>
            </section>

            <!-- Hero Banner Image -->
            <div class="project-details-img" data-aos="zoom-in">
                <img src="/assets/project2.jpeg" alt="QA Brains Automation Project Banner">
            </div>

            <!-- Info Box Card -->
            <div data-aos="zoom-in">
                <div class="d-flex project-infos-wrap shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <img src="/assets/icon2.png" alt="Star" class="star-icon">
                    
                    <div class="project-details-info flex-1">
                        <h4>QA Brains Automation Project</h4>
                        <p>Designed and built an end-to-end automation suite using Java and Playwright. Features Page Object Model (POM) architecture, automated cross-browser test runs, dynamic data generation, and detailed test execution reports.</p>
                        <p>Ensures high regression test velocity and reliable CI/CD integration with zero false positives.</p>
                    </div>

                    <div class="project-details-info flex-1">
                        <h4>About</h4>
                        <p>An enterprise-grade test automation suite implementing robust assertion pipelines, parallel test execution, and comprehensive reporting.</p>
                    </div>
                </div>
            </div>

            <!-- Project Showcase Banner 2 -->
            <div class="project-details-2-img mb-24" data-aos="zoom-in">
                <img src="/assets/project-dt-1.jpeg" alt="Showcase Banner">
            </div>

            <!-- Project Overview & Details Meta Box -->
            <div data-aos="zoom-in">
                <div class="project-about-2 d-flex shadow-box mb-24">
                    <img src="/assets/bg1.png" alt="BG" class="bg-img">
                    <div class="left-details">
                        <img src="/assets/icon2.png" alt="Star" class="star-icon">
                        <ul>
                            <li>
                                <p>Year</p>
                                <h5>2023</h5>
                            </li>
                            <li>
                                <p>Client</p>
                                <h5>QA Brains</h5>
                            </li>
                            <li>
                                <p>Services</p>
                                <h5>Java & Playwright</h5>
                            </li>
                            <li>
                                <p>Project</p>
                                <h5>QA Brains Automation</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="right-details">
                        <h4>Description</h4>
                        <p>Automated test framework development utilizing Java, Playwright, TestNG/JUnit, and HTML test report generation for continuous testing integration.</p>
                    </div>
                </div>
            </div>

            <!-- Next Project Button -->
            <div class="container d-flex align-items-center justify-content-center mt-24 mb-24" data-aos="zoom-in">
                <a href="/works/qa-brains-ts-playwright" class="big-btn shadow-box">Next Project</a>
            </div>

        </div>
    </section>
</BaseLayout>
