---
// src/pages/404.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found - Raiyan Uddin" bodyClass="main-404page">
  <section class="about-area">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-md-8 text-center" style="padding: 60px 0;">
          <div data-aos="zoom-in">
            <div class="shadow-box" style="padding: 60px 40px; border-radius: 30px; position: relative; overflow: hidden;">
              <img src="/My-Portfolio/assets/bg1.png" alt="BG" class="bg-img" />
              
              <div class="mb-24">
                <h1 style="font-size: 84px; font-weight: 700; color: #5B78F6; margin-bottom: 12px; letter-spacing: -2px;">
                  404
                </h1>
                <h2 style="color: #fff; font-size: 28px; font-weight: 500; margin-bottom: 16px;">
                  Page Not Found
                </h2>
                <p style="color: #9f9f9f; font-size: 15px; max-width: 500px; margin: 0 auto 32px; line-height: 1.6;">
                  Oops! The page you are looking for doesn't exist or may have been moved. Let's get you back on track.
                </p>
              </div>

              <div class="d-flex justify-content-center">
                <a href="/My-Portfolio/" class="theme-btn" style="padding: 12px 32px; font-size: 15px;">
                  Back to Home
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
