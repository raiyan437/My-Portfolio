---
// src/pages/works.astro
import BaseLayout from "../layouts/BaseLayout.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<BaseLayout title="Works - Raiyan Uddin" bodyClass="main-workspage">
  <section class="projects-area">
    <div class="container">
      <div class="row">
        <!-- Left: Works Column 1 (4 columns) -->
        <div class="col-md-4 mb-24">
          <!-- Mobile Heading Title -->
          <div class="d-md-none mb-24" data-aos="fade-up">
            <h1 class="section-heading">
              <img src={`${base}assets/star-2.png`} alt="img" />
              All Projects
              <img src={`${base}assets/star-2.png`} alt="img" />
            </h1>
          </div>

          <!-- Project 1 (MrMax) -->
          <div class="mb-24">
            <div data-aos="zoom-in">
              <div class="project-item shadow-box">
                <a href={`${base}works/mrmax/`} class="overlay-link"></a>
                <img
                  src={`${base}assets/bg1.png`}
                  alt="img"
                  class="bg-img"
                />
                <div class="project-img">
                  <img
                    class="proj-img"
                    src={`${base}assets/project1.png`}
                    alt="MrMax"
                  />
                </div>
                <div class="d-flex align-items-center justify-content-between">
                  <div class="project-info">
                    <p>WEB DESIGNING</p>
                    <h2>MrMax</h2>
                  </div>
                  <a href={`${base}works/mrmax/`} class="project-btn">
                    <img src={`${base}assets/icon.svg`} alt="img" />
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Project 2 (QA Brains Automation Project - Java) -->
          <div class="mb-24">
            <div data-aos="zoom-in">
              <div class="project-item shadow-box">
                <a
                  href={`${base}works/qa-brains-java-playwright/`}
                  class="overlay-link"></a>
                <img
                  src={`${base}assets/bg1.png`}
                  alt="img"
                  class="bg-img"
                />
                <div class="project-img">
                  <img
                    class="proj-img"
                    src={`${base}assets/project2.png`}
                    alt="QA Brains Automation Project"
                  />
                </div>
                <div class="d-flex align-items-center justify-content-between">
                  <div class="project-info">
                    <p>Java & Playwright</p>
                    <h2>QA Brains Automation</h2>
                  </div>
                  <a
                    href={`${base}works/qa-brains-java-playwright/`}
                    class="project-btn"
                  >
                    <img src={`${base}assets/icon.svg`} alt="img" />
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Project 3 (QA Brains Automation Project - TypeScript) -->
          <div class="mb-24">
            <div data-aos="zoom-in">
              <div class="project-item shadow-box">
                <a
                  href={`${base}works/qa-brains-ts-playwright/`}
                  class="overlay-link"></a>
                <img
                  src={`${base}assets/bg1.png`}
                  alt="img"
                  class="bg-img"
                />
                <div class="project-img">
                  <img
                    class="proj-img"
                    src={`${base}assets/project3.png`}
                    alt="QA Brains Automation Project"
                  />
                </div>
                <div class="d-flex align-items-center justify-content-between">
                  <div class="project-info">
                    <p>Typescript & Playwright</p>
                    <h2>QA Brains Automation</h2>
                  </div>
                  <a
                    href={`${base}works/qa-brains-ts-playwright/`}
                    class="project-btn"
                  >
                    <img src={`${base}assets/icon.svg`} alt="img" />
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Works Column 2 & 3 (8 columns) -->
        <div class="col-md-8 mb-24">
          <!-- Desktop Header Title -->
          <div class="d-none d-md-block mb-24" data-aos="fade-up">
            <h1 class="section-heading justify-content-start">
              <img src={`${base}assets/star-2.png`} alt="img" />
              All Projects
              <img src={`${base}assets/star-2.png`} alt="img" />
            </h1>
          </div>

          <div class="row">
            <!-- Sub-Column 1 -->
            <div class="col-md-6 mb-24">
              <!-- Project 4 (Restful Booker) -->
              <div class="mb-24">
                <div data-aos="zoom-in" class="flex-1">
                  <div class="project-item shadow-box">
                    <a
                      href={`${base}works/restful-booker/`}
                      class="overlay-link"></a>
                    <img
                      src={`${base}assets/bg1.png`}
                      alt="img"
                      class="bg-img"
                    />
                    <div class="project-img">
                      <img
                        class="proj-img"
                        src={`${base}assets/project4.png`}
                        alt="Restful Booker"
                      />
                    </div>
                    <div
                      class="d-flex align-items-center justify-content-between"
                    >
                      <div class="project-info">
                        <p>API Automation</p>
                        <h2>Restful Booker</h2>
                      </div>
                      <a
                        href={`${base}works/restful-booker/`}
                        class="project-btn"
                      >
                        <img src={`${base}assets/icon.svg`} alt="img" />
                      </a>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Project 5 (GCC Mealkun) -->
              <div class="mb-24">
                <div data-aos="zoom-in" class="flex-1">
                  <div class="project-item shadow-box">
                    <a
                      href={`${base}works/gcc-mealkun/`}
                      class="overlay-link"></a>
                    <img
                      src={`${base}assets/bg1.png`}
                      alt="img"
                      class="bg-img"
                    />
                    <div class="project-img">
                      <img
                        class="proj-img"
                        src={`${base}assets/project5.png`}
                        alt="GCC Mealkun"
                      />
                    </div>
                    <div
                      class="d-flex align-items-center justify-content-between"
                    >
                      <div class="project-info">
                        <p>MOBILE DESIGNING</p>
                        <h2>GCC Mealkun</h2>
                      </div>
                      <a
                        href={`${base}works/gcc-mealkun/`}
                        class="project-btn"
                      >
                        <img src={`${base}assets/icon.svg`} alt="img" />
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Sub-Column 2 -->
            <div class="col-md-6 mb-24">
              <!-- Project 6 (BSEC IPO System) -->
              <div class="mb-24">
                <div data-aos="zoom-in" class="flex-1">
                  <div class="project-item shadow-box">
                    <a
                      href={`${base}works/bsec-ipo-system/`}
                      class="overlay-link"></a>
                    <img
                      src={`${base}assets/bg1.png`}
                      alt="img"
                      class="bg-img"
                    />
                    <div class="project-img">
                      <img
                        class="proj-img"
                        src={`${base}assets/project6.png`}
                        alt="BSEC IPO System"
                      />
                    </div>
                    <div
                      class="d-flex align-items-center justify-content-between"
                    >
                      <div class="project-info">
                        <p>BRANDING</p>
                        <h2>BSEC IPO System</h2>
                      </div>
                      <a
                        href={`${base}works/bsec-ipo-system/`}
                        class="project-btn"
                      >
                        <img src={`${base}assets/icon.svg`} alt="img" />
                      </a>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Project 7 (dNothi) -->
              <div class="mb-24">
                <div data-aos="zoom-in" class="flex-1">
                  <div class="project-item shadow-box">
                    <a href={`${base}works/dnothi/`} class="overlay-link"
                    ></a>
                    <img
                      src={`${base}assets/bg1.png`}
                      alt="img"
                      class="bg-img"
                    />
                    <div class="project-img">
                      <img
                        class="proj-img"
                        src={`${base}assets/project7.png`}
                        alt="dNothi"
                      />
                    </div>
                    <div
                      class="d-flex align-items-center justify-content-between"
                    >
                      <div class="project-info">
                        <p>WEB DESIGNING</p>
                        <h2>dNothi</h2>
                      </div>
                      <a href={`${base}works/dnothi/`} class="project-btn">
                        <img src={`${base}assets/icon.svg`} alt="img" />
                      </a>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Project 8 (Practice Management System) -->
              <div class="mb-24">
                <div data-aos="zoom-in" class="flex-1">
                  <div class="project-item shadow-box">
                    <a
                      href={`${base}works/practice-management-system/`}
                      class="overlay-link"></a>
                    <img
                      src={`${base}assets/bg1.png`}
                      alt="img"
                      class="bg-img"
                    />
                    <div class="project-img">
                      <img
                        class="proj-img"
                        src={`${base}assets/project8.png`}
                        alt="Practice Management System"
                      />
                    </div>
                    <div
                      class="d-flex align-items-center justify-content-between"
                    >
                      <div class="project-info">
                        <p>ARCHITECTURE</p>
                        <h2>Practice Management</h2>
                      </div>
                      <a
                        href={`${base}works/practice-management-system/`}
                        class="project-btn"
                      >
                        <img src={`${base}assets/icon.svg`} alt="img" />
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
