---
// src/pages/contact.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout title="Contact - Raiyan Uddin" bodyClass="main-contactpage">
  <section class="contact-area">
    <div class="container">
      <div class="gx-row d-flex justify-content-between gap-24">
        <!-- Left: Contact Details Column -->
        <div class="contact-infos">
          <h4 data-aos="fade-up">Contact Info</h4>

          <ul class="contact-details">
            <!-- Mail -->
            <li class="d-flex align-items-center" data-aos="zoom-in">
              <div class="icon-box shadow-box">
                <i class="iconoir-mail"></i>
              </div>
              <div class="right">
                <span>MAIL US</span>
                <h5>raiyan.uddin.37.pro@gmail.com</h5>
              </div>
            </li>

            <!-- Phone -->
            <li class="d-flex align-items-center" data-aos="zoom-in">
              <div class="icon-box shadow-box">
                <i class="iconoir-phone"></i>
              </div>
              <div class="right">
                <span>Contact Us</span>
                <h5>+88 018 61277634</h5>
              </div>
            </li>

            <!-- Address -->
            <li class="d-flex align-items-center" data-aos="zoom-in">
              <div class="icon-box shadow-box">
                <i class="iconoir-pin-alt"></i>
              </div>
              <div class="right">
                <span>Location</span>
                <h5>Dhaka <br />Bangladesh</h5>
              </div>
            </li>
          </ul>

          <h4 data-aos="fade-up">Social Info</h4>
          <SocialLinks boxClass="inner-profile-icons shadow-box" />
        </div>

        <!-- Right: Form Panel -->
        <div data-aos="zoom-in" class="contact-form">
          <div class="shadow-box">
            <img src="/My-Portfolio/assets/bg1.png" alt="img" class="bg-img" />
            <img
              src="/My-Portfolio/assets/icon2.png"
              alt="img"
              class="star-icon"
            />

            <h2>Let’s work <span>together.</span></h2>

            <form id="cf-form" class="wpcf7-form" novalidate="novalidate">
              <!-- Success Message -->
              <div
                class="alert alert-success messenger-box-contact__msg"
                id="msg-alert"
                style="display: none; background: rgba(91, 120, 246, 0.15); border: 1px solid var(--primary_color); color: #fff; border-radius: 10px; padding: 12px 16px; margin-bottom: 20px;"
                role="alert"
              >
                Your message was sent successfully.
              </div>

              <div class="input-group">
                <input
                  type="text"
                  id="full-name"
                  name="name"
                  required
                  placeholder="Name *"
                />
              </div>

              <div class="input-group">
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="Email *"
                />
              </div>

              <div class="input-group">
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  required
                  placeholder="Your Subject *"
                />
              </div>

              <div class="input-group">
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  placeholder="Your Message *"></textarea>
              </div>

              <div class="input-group mb-0">
                <button
                  class="theme-btn submit-btn"
                  type="submit"
                  id="submit-btn">Send Message</button
                >
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById("cf-form") as HTMLFormElement;
    const msgAlert = document.getElementById("msg-alert");
    const submitBtn = document.getElementById("submit-btn");

    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (submitBtn) submitBtn.textContent = "Sending...";

        const formData = new FormData(form);

        try {
          const response = await fetch("https://api.web3forms.com/submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify({
              access_key: "b947c699-2708-410d-b2a6-b51f893e1bfa",
              name: formData.get("name"),
              email: formData.get("email"),
              subject: formData.get("subject"),
              message: formData.get("message"),
            }),
          });
          const result = await response.json();
          if (result.success) {
            if (msgAlert) {
              msgAlert.style.display = "block";
              msgAlert.textContent = "Your message was sent successfully!";
            }
            form.reset();
          } else {
            window.location.href = `mailto:raiyan.uddin.37.pro@gmail.com?subject=${encodeURIComponent(String(formData.get("subject") || ""))}&body=${encodeURIComponent(String(formData.get("message") || ""))}`;
          }
        } catch (err) {
          window.location.href = `mailto:raiyan.uddin.37.pro@gmail.com?subject=${encodeURIComponent(String(formData.get("subject") || ""))}&body=${encodeURIComponent(String(formData.get("message") || ""))}`;
        } finally {
          if (submitBtn) submitBtn.textContent = "Send Message";
        }
      });
    }
  </script>
</BaseLayout>
